# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
TUSHARE_TOKEN=your_tushare_token_here

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/astock_news
REDIS_URL=redis://redis:6379/0

# === Service Config ===
COLLECT_INTERVAL=300          # 新闻采集间隔（秒）
BERT_CONFIDENCE_THRESHOLD=0.90 # 低于此值触发LLM精分类
TOP_K_STOCKS=5                # 每条新闻匹配的龙头股数量
VECTOR_DIM=768                # sentence-transformers 向量维度

# === News Sources ===
ENABLE_CLS=true               # 财联社
ENABLE_EASTMONEY=true         # 东方财富
ENABLE_SINA=true              # 新浪财经
ENABLE_RSS=true               # RSS聚合

# === Logging ===
LOG_LEVEL=INFO
